<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F2EFF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- ===== FOTO PRODUK ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E5DFF5">

            <ImageView
                android:id="@+id/imgProduk"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/product"
                android:contentDescription="@string/desc_foto_produk" />

        </androidx.cardview.widget.CardView>

        <!-- ===== INFO PRODUK ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Baris Nama + Badge Aktif -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Nama Produk -->
                <TextView
                    android:id="@+id/tvNamaProduk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_nama_produk"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <!-- Badge Aktif (hijau, border, rounded) -->
                <LinearLayout
                    android:id="@+id/layoutStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/bg_badge_aktif">

                    <ImageView
                        android:id="@+id/imgStatus"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ceklist"
                        android:contentDescription="@string/desc_status"
                        app:tint="#2E7D32" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_aktif"
                        android:textSize="12sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Harga -->
            <TextView
                android:id="@+id/tvHarga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_harga"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#6A3DE8"
                android:layout_marginTop="3dp" />

            <!-- Kategori (ikon segitiga + nama) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/categori"
                    android:contentDescription="@string/desc_kategori"
                    app:tint="#555555" />

                <TextView
                    android:id="@+id/tvKategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_kategori"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginStart="5dp" />

            </LinearLayout>

            <!-- Stok + Cabang -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <!-- Ikon stok (kotak/inventory) -->
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/store"
                    android:contentDescription="@string/desc_stok"
                    app:tint="#4CAF50" />

                <TextView
                    android:id="@+id/tvStok"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_stok"
                    android:textSize="12sp"
                    android:textColor="#4CAF50"
                    android:layout_marginStart="5dp" />

                <!-- Spacer -->
                <Space android:layout_width="14dp" android:layout_height="1dp" />

                <!-- Ikon cabang (toko) -->
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/store"
                    android:contentDescription="@string/desc_cabang" />

                <TextView
                    android:id="@+id/tvCabang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_cabang"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginStart="5dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>